[Remote Filter]
HK节点 = NameRegex, FilterKey = "(?i)(港|HK|Hong)"
TW节点 = NameRegex, FilterKey = "(?i)(台|TW|Tai)"
JP节点 = NameRegex, FilterKey = "(?i)(日本|川日|东京|大阪|泉日|埼玉|沪日|深日|JP|Japan)"
KR节点 = NameRegex, FilterKey = "(?i)(KR|Korea|KOR|首尔|韩|韓)"
US节点 = NameRegex, FilterKey = "(?i)(美|波特兰|达拉斯|俄勒冈|凤凰城|费利蒙|硅谷|拉斯维加斯|洛杉矶|圣何塞|圣克拉拉|西雅图|芝加哥|US|United States)"
SG节点 = NameRegex, FilterKey = "(?i)(新加坡|坡|狮城|SG|Singapore)"
ALL节点 = NameRegex, FilterKey = ".*"
